// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 🏢 ŞİRKETLER (Cari Hesaplar - Müşteri & Tedarikçi Firmalar)
model Company {
  id        String   @id @default(uuid())
  name      String
  type      String   // CUSTOMER veya SUPPLIER
  taxNumber String?
  address   String?
  phone     String?
  email     String?
  balance   Decimal  @default(0) // + Alacak, - Borç
   
  // İlişkiler
  invoices     Invoice[]
  transactions Transaction[] 
  offers       Offer[]       // Şirkete verilen teklifler
  customers    Customer[]    // Şirket altındaki yetkili kişiler/müşteriler
   
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 👤 MÜŞTERİLER (Bireysel Müşteriler veya Firma Yetkilileri)
// HATA ÇÖZÜMÜ: Bu model eksik olduğu için hata alıyordun.
model Customer {
  id        String   @id @default(uuid())
  name      String   // Ad Soyad
  email     String?
  phone     String?
  address   String?
  taxId     String?  // TC Kimlik No
  
  // Bir şirkete bağlı çalışıyor olabilir (Opsiyonel)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  // İlişkiler
  offers    Offer[]   // Müşteriye verilen teklifler
  invoices  Invoice[] // Müşteriye kesilen faturalar

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 📦 ÜRÜNLER
model Product {
  id           String   @id @default(uuid())
  name         String
  barcode      String?
  stock        Float    @default(0)
  unit         String   @default("Adet")
  buyPrice     Decimal
  sellPrice    Decimal
  criticalQty  Int      @default(10)
  vatRate      Int      @default(20) 

  licenseKey   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
   
  invoiceItems InvoiceItem[]
  offerItems   OfferItem[]   // Tekliflerde kullanılan ürünler
}

// 🧾 FATURALAR
model Invoice {
  id          String   @id @default(uuid())
  type        String   @default("SALES") // SALES veya PURCHASE
  status      String   @default("PENDING") // PENDING veya PAID

  companyId   String?  // Firma ID'si (Opsiyonel olabilir)
  company     Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  customerId  String?  // Bireysel Müşteri ID'si (Opsiyonel)
  customer    Customer? @relation(fields: [customerId], references: [id])
   
  totalAmount Decimal  @default(0)
  date        DateTime @default(now())
   
  items       InvoiceItem[]
   
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 📝 FATURA KALEMLERİ
model InvoiceItem {
  id        String   @id @default(uuid())
   
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
   
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
   
  quantity  Float
  price     Decimal
  total     Decimal
}

// 1. 📄 TEKLİF (OFFER) MODELİ
model Offer {
  id          String      @id @default(uuid())
  
  companyId   String?     // Teklif verilen şirket (Opsiyonel)
  company     Company?    @relation(fields: [companyId], references: [id])
  
  customerId  String?     // Teklifin verildiği kişi/müşteri (Opsiyonel)
  customer    Customer?   @relation(fields: [customerId], references: [id])
  
  totalAmount Float       // Toplam Tutar
  currency    String      @default("TRY") // Para birimi (TRY, USD, EUR)
  status      String      @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED, CONVERTED
  validUntil  DateTime?   // Teklifin geçerlilik tarihi
  note        String?     // Müşteriye not
  
  items       OfferItem[] // Teklif kalemleri

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// 2. 📎 TEKLİF KALEMLERİ (OFFER ITEMS)
model OfferItem {
  id        String  @id @default(uuid())
  offerId   String
  offer     Offer   @relation(fields: [offerId], references: [id], onDelete: Cascade)
  
  productId String
  product   Product @relation(fields: [productId], references: [id])
  
  quantity  Int
  price     Float
  vatRate   Float   @default(20) // KDV Oranı (Güncel oran %20)
  total     Float
}

// 👥 PERSONELLER
model Employee {
  id        String   @id @default(uuid())
  firstName String
  lastName  String
  title     String?
  phone     String?
  email     String?
  salary    Decimal  @default(0)
   
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
} 

// 🔑 LİSANSLAR
model License {
  id        String   @id @default(uuid())
  key       String   @unique
  owner     String
  isActive  Boolean  @default(true)
  expiresAt DateTime?
  createdAt DateTime @default(now())
}

// 💰 KASA & BANKA HESAPLARI
model FinancialAccount {
  id        String        @id @default(uuid())
  name      String        // Örn: "Merkez Kasa", "Ziraat Bankası"
  type      AccountType   @default(CASH)
  balance   Decimal       @default(0)
  currency  String        @default("TRY")
  iban      String?       
   
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // İlişkiler
  transactions Transaction[]
  expenses     Expense[]
}

// 💸 PARA HAREKETLERİ (Tahsilat/Ödeme)
model Transaction {
  id          String          @id @default(uuid())
  amount      Decimal
  type        TransactionType
  description String?
  category    String?
  date        DateTime        @default(now())

  // Hangi kasaya/bankaya bağlı?
  account     FinancialAccount? @relation(fields: [accountId], references: [id])
  accountId   String?

  // Hangi firmayla ilgili?
  company     Company?          @relation(fields: [companyId], references: [id])
  companyId   String?

  createdAt   DateTime          @default(now())
}

// ⚙️ GENEL AYARLAR
model Settings {
  id          String   @id @default(uuid())
  companyName String
  address     String?
  phone       String?
  email       String?
  taxId       String?
  iban        String?
  logoUrl     String?
  terms       String?
   
  updatedAt   DateTime @updatedAt
}

// 📂 GİDER KATEGORİLERİ
model ExpenseCategory {
  id        String    @id @default(uuid())
  name      String    @unique
  expenses  Expense[]
  createdAt DateTime  @default(now())
}

// 🧾 GİDERLER (Genel Harcamalar)
model Expense {
  id          String   @id @default(uuid())
  description String
  amount      Float
  date        DateTime @default(now())
   
  // Kategori İlişkisi
  categoryId  String
  category    ExpenseCategory @relation(fields: [categoryId], references: [id])

  // Kasa/Banka İlişkisi
  accountId   String
  account     FinancialAccount @relation(fields: [accountId], references: [id])

  createdAt   DateTime @default(now())
}

// 📌 ENUMLAR
enum AccountType {
  CASH
  BANK
  POS
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}